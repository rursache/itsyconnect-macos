# Auth – required
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# Random string for session encryption (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Encryption – required
# Master key for encrypting ASC credentials. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# AI – optional (features hidden if not set)
# ANTHROPIC_API_KEY=

# Database – optional (defaults to /data/itsyship.db in Docker, ./data/itsyship.db locally)
# DATABASE_PATH=/data/itsyship.db
